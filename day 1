1.Largest of three

a=int(input())
b=int(input())
c=int(input())
if a>b and a>c:
    print("a is largest")
elif b>a and b>c:
    print("b is largest")
elif c>a and c>b:
    print("c is largest")
else:
    print("Numbers are equal")

